{
  "name": "upload-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --bun next dev",
    "bot:dev": "cross-env UPLOAD_ENDPOINT=http://localhost:3000/api/upload bun src/bot/index.ts",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "db:generate": "drizzle-kit generate",
    "typecheck": "tsc --noEmit",
    "codecheck": "bunx biome check .",
    "codecheck:fix": "bunx biome check --fix .",
    "test": "bun test",
    "test:e2e": "playwright test",
    "lint": "biome check",
    "format": "biome format --write",
    "prod:up": "docker compose up --build -d",
    "prod:down": "docker compose down",
    "tunnel:up": "docker compose -f docker-compose.yml -f docker-compose.tunnel.yml up --build -d",
    "tunnel:dev": "docker compose -f docker-compose.yml -f docker-compose.tunnel.yml -f docker-compose.tunnel.dev.yml up -d caddy cloudflared && concurrently -n web,bot -c blue,magenta \"bun run dev\" \"bun run bot:dev\"",
    "tunnel:down": "docker compose -f docker-compose.yml -f docker-compose.tunnel.yml down"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tus/file-store": "^2.1.0",
    "@tus/server": "^2.4.2",
    "@uppy/core": "^5.2.0",
    "@uppy/dashboard": "^5.1.1",
    "@uppy/react": "^5.2.0",
    "@uppy/tus": "^5.1.1",
    "better-auth": "^1.6.25",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "discord.js": "^14.27.0",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.3",
    "file-type": "^22.0.1",
    "lucide-react": "^1.26.0",
    "next": "16.2.11",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "radix-ui": "1.6.4",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "server-only": "^0.0.1",
    "shadcn": "^4.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@happy-dom/global-registrator": "^20.11.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
