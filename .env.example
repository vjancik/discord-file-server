# ── Public identity ────────────────────────────────────────────────────────────
# Hostname users reach the app at. Caddy provisions Let's Encrypt for it,
# and generated links use https://$DOMAIN. DNS must point at this box.
DOMAIN=files.example.com
# Optional override for the derived base URL. Set for local dev without Caddy.
# For dev-through-tunnel (bun run beta:dev), set to https://$DOMAIN instead —
# dev mode otherwise defaults to localhost links.
# BASE_URL=http://localhost:3000

# ── Storage & quota ────────────────────────────────────────────────────────────
# Total bytes for completed files. Accepts raw bytes or suffixed values
# (KB/MB/GB/TB decimal, KiB/MiB/GiB/TiB binary). Per-user quota is
# STORAGE_LIMIT / active_users, recomputed at upload time.
STORAGE_LIMIT=500GB
# Total bytes the staging area (SSD, in-progress uploads) may hold. Uploads
# that would exceed it wait for in-flight uploads to drain, or are rejected
# when nothing is draining. Size it to your staging SSD (minus ~1 GiB
# headroom); the app also clips to the volume's true free space at runtime.
STAGING_LIMIT=100GB
# Optional global per-file cap. Unset = per-file max is the user's quota.
# MAX_FILE_SIZE=50GB
# Optional default expiry for new files ("30d", "12h", "1w"). Unset = never.
# DEFAULT_FILE_EXPIRY=30d

# ── Paths ──────────────────────────────────────────────────────────────────────
# Local/dev paths. In Docker these are overridden by docker-compose.yml
# (fixed container paths) — set the HOST_* vars below instead.
STAGING_DIR=./.data/staging
STORAGE_DIR=./.data/uploads
DATABASE_PATH=./.data/db/app.sqlite

# ── Docker Compose host mounts (production) ────────────────────────────────────
# Host directories mapped into the containers; must be writable by uid 1001.
# For beta testing via the tunnel overlay, in-repo paths work too:
#   ./data/beta/uploads · ./data/beta/staging · ./data/beta/db · ./data/beta/replica
HOST_STORAGE_DIR=/mnt/storage/uploads
HOST_STAGING_DIR=/mnt/ssd/staging
HOST_DB_DIR=/mnt/ssd/dfs-db
HOST_REPLICA_DIR=/mnt/storage/dfs-db-replica

# ── Cloudflare Tunnel (docker-compose.tunnel.yml — beta/CGNAT testing only) ────
# Connector token from Zero Trust → Networks → Tunnels → your tunnel.
# The tunnel's public hostname must route $DOMAIN → HTTP → caddy:80.
# CLOUDFLARE_TUNNEL_TOKEN=

# ── Authorization ──────────────────────────────────────────────────────────────
# Comma-separated Discord guild IDs whose members may sign in.
ALLOWED_GUILD_IDS=123456789012345678
# Comma-separated Discord user IDs with admin access.
ADMIN_DISCORD_IDS=123456789012345678

# ── Discord OAuth (https://discord.com/developers/applications) ────────────────
# Redirect URL to register: https://$DOMAIN/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Ask Discord for the user's email at sign-in (adds the `email` OAuth scope
# to the consent screen). The app itself never uses the email — leave off
# unless you plan to contact users; a placeholder address is stored instead.
# Accepts true/1/yes/on and false/0/no/off.
REQUIRE_EMAIL=false

# ── Discord bot (separate container; docs/planned.md for roadmap) ──────────────
# Bot token from the same Discord application (Bot tab). The bot registers a
# /upload slash command in ALLOWED_GUILD_IDS and posts pending uploads for
# review. Leave unset if you don't run the bot service.
DISCORD_BOT_TOKEN=
# Channel where pending uploads appear with Approve/Reject buttons. Only
# ADMIN_DISCORD_IDS members can use the buttons.
ADMIN_CHANNEL_ID=

# ── Better Auth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
