# Data plane (PRD §3): Caddy terminates TLS for {$DOMAIN} and serves file
# bytes for /f/* straight from disk — Range requests, ETags, conditional GETs.
# Everything else is reverse-proxied to the Next.js app.
{$DOMAIN} {
	handle_path /f/* {
		root * /srv/uploads

		# Keep leaked capability URLs out of search engines (PRD §8).
		header X-Robots-Tag noindex

		# Non-media downloads directly; media must NEVER get an attachment
		# disposition or Discord embeds die (PRD §4). Keep this extension list
		# in sync with VIDEO_MIME/IMAGE_MIME/AUDIO_MIME in
		# src/server/files/type-policy.ts.
		@nonmedia not path_regexp \.(mp4|m4v|webm|mov|mkv|avi|png|jpe?g|gif|webp|avif|bmp|tiff|heic|heif|mp3|wav|ogg|oga|opus|flac|m4a|aac)$
		header @nonmedia Content-Disposition attachment

		# /f/* URLs are content-addressed (fileId + fileName), so bytes for a
		# given URL never change — cache hard. A deleted file 404s from the
		# origin regardless, and the app hands out fresh URLs, so no stale
		# content leaks. Caddy's file_server still sets ETag/Last-Modified and
		# honors Range/conditional GETs on top of this.
		header Cache-Control "public, max-age=31536000, immutable"

		# No `browse` directive: directory listing stays off (PRD §8).
		file_server
	}

	handle {
		reverse_proxy app:3000
	}
}
